# NexEvent Hub Environment Variables Configuration

# Copy this file to '.env' to load real Firebase Cloud connection details:
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-storage-bucket
# VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
# VITE_FIREBASE_APP_ID=your-app-id

# If left empty, the application will automatically enter Local Sandbox Fallback Mode
# storing all events, volunteers, sponsors, and tickets in browser Session/LocalStorage!
